{
  "name": "zentao-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Browser and Node.js SDK for ZenTao API",
  "license": "MIT",
  "author": "Sun Hao <sunhao@chandao.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/catouse/zentao-api.git"
  },
  "keywords": [
    "zentao",
    "禅道",
    "api",
    "sdk",
    "browser"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./browser": "./dist/browser/zentao-api.global.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.json && bun run scripts/build-browser.ts",
    "prepublishOnly": "bun run test && bun run typecheck && bun run build"
  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
